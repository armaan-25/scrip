# Ramp Developer API credentials (sandbox or production).
# Leave RAMP_CLIENT_ID / RAMP_CLIENT_SECRET unset to run against the local
# MockRampGateway instead of a real Ramp connection.
RAMP_CLIENT_ID=
RAMP_CLIENT_SECRET=
RAMP_API_BASE_URL=https://demo-api.ramp.com

# Separate static API key for the ai-usage/unified broadcast (AI Usage
# Tracking) - different auth model from the OAuth client-credentials pair
# above. Generated from your own Ramp account (Settings -> Integrations),
# not the Developer Console app registration.
RAMP_AI_USAGE_API_KEY=

# The real Ramp Fund ID backing the "research" budget in scrip.yaml.
RAMP_RESEARCH_FUND_ID=

ANTHROPIC_API_KEY=
